{
  "name": "localpdf-v6",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 3000",
    "dev:web": "astro dev --root website",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:web\" --names \"APP,WEB\" --prefix-colors \"cyan,magenta\"",
    "lint": "node -e \"console.log('lint: no-op')\"",
    "preview:e2e": "vite preview --host 127.0.0.1 --port 4173 --strictPort",
    "build": "tsc -p tsconfig.json && vite build",
    "build:web": "astro build --root website",
    "build:all": "node build-vercel.mjs",
    "build:vercel": "node build-vercel.mjs",
    "release:check": "npm test && npm run build && npm run audit:workerization:strict",
    "release:check:fast": "npm test && npm run build",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:watch": "node --import tsx --test --watch src/**/*.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:studio-edit": "playwright test e2e/studio-edit-advanced-formatting.spec.ts e2e/studio-edit-batch-save.spec.ts e2e/studio-edit-precision.spec.ts e2e/studio-edit-save-undo-redo.spec.ts e2e/studio-edit-telemetry-actions.spec.ts e2e/studio-edit-telemetry-undo-redo-single.spec.ts e2e/studio-edit-telemetry.spec.ts e2e/studio-edit-text-save.spec.ts",
    "fixtures:pdfs": "node scripts/generate-e2e-pdf-fixtures.mjs",
    "report:fallback-budget": "node scripts/fallback-budget-summary.mjs",
    "audit:workerization": "node scripts/workerization-audit.mjs",
    "audit:workerization:strict": "node scripts/workerization-audit.mjs --strict"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.0",
    "@astrojs/rss": "^4.0.16",
    "@astrojs/sitemap": "^3.7.1",
    "@fontsource/noto-sans": "^5.2.10",
    "@pdf-lib/fontkit": "^1.1.1",
    "astro": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "exceljs": "^4.4.0",
    "fast-xml-builder": "^1.1.0",
    "fast-xml-parser": "^5.5.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "konva": "^9.3.22",
    "lucide-react": "^0.576.0",
    "mammoth": "^1.11.0",
    "pdf-lib": "^1.17.1",
    "pdf-lib-plus-encrypt": "file:vendor/pdf-lib-plus-encrypt/pdf-lib-plus-encrypt-1.1.0.tgz",
    "postcss": "^8.5.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-konva": "^18.2.10",
    "react-router-dom": "^6.30.1",
    "tailwindcss": "^3.4.17",
    "tesseract.js": "^5.1.1",
    "use-image": "^1.1.4",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.10",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.16",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.4.1",
    "canvas": "^3.2.1",
    "concurrently": "^9.2.1",
    "pdfjs-dist": "^5.4.624",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  }
}
