*.spec.tsx

# Development config files
.gitignore
.vercelignore

# GitHub specific files (not needed for deployment)
.github/
.github/*

# Git files
.git/
.git/*
.gitattributes

# Development dependencies tracking
package-lock.json

# Build config files are now KEPT for Vercel build:
# tsconfig.json - KEPT (needed for TypeScript)
# tsconfig.node.json - KEPT (needed for Vite)
# vite.config.ts - KEPT (needed for Vite build)
# postcss.config.js - KEPT (needed for Tailwind)
# tailwind.config.js - KEPT (needed for styles)

# Documentation files (not needed for app runtime)
README.md
FAQ.md
PRIVACY.md