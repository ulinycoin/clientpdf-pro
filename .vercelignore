temp/

# Claude AI memory system (development only)
.claude/
.claude/*

# Development documentation and scripts
quick-start.sh
claude-start.sh
claude-end.sh
LOCAL_DEVELOPMENT.md
BUILD.md
TASK_TRACKER.md
