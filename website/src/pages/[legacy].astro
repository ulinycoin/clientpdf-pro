const legacyRoutes = getLegacyRoutes();
type LegacySlug = keyof ReturnType<typeof getLegacyRoutes>;

export function getStaticPaths() {
  const legacyRoutes = {
    'add-form-fields-pdf': true,
    'add-text-pdf': true,
    'compress-pdf': true,
    'delete-pages-pdf': true,
    'extract-pages-pdf': true,
    'flatten-pdf': true,
    'images-to-pdf': true,
    'merge-pdf': true,
    'ocr-pdf': true,
    'organize-pdf': true,
    'pdf-to-images': true,
    'pdf-to-word': true,
    'protect-pdf': true,
    'rotate-pdf': true,
    'sign-pdf': true,
    'split-pdf': true,
    'unlock-pdf': true,
    'watermark-pdf': true,
    'word-to-pdf': true,
  } as const;

  return Object.keys(legacyRoutes).map((slug) => ({
    params: { legacy: slug },
    props: {
      slug,
    },
  }));
}

const { slug } = Astro.props as { slug: LegacySlug };
const page = legacyRoutes[slug];
---

<LegacyArchivePage
  title={page.title}
  description={page.description}
  canonical={`https://localpdf.online/${slug}`}
  heading={page.heading}
  body={page.body}
  primaryHref={page.primaryHref}
  primaryLabel={page.primaryLabel}
  secondaryHref={page.secondaryHref}
  secondaryLabel={page.secondaryLabel}
/>
