---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { getAppUrl } from '../utils/app-url';

const title = 'About | LocalPDF';
const description = 'LocalPDF is a privacy-first PDF app built for clear workflows, local-first handling, and practical document work in one place.';
const canonical = 'https://localpdf.online/about';
const image = 'https://localpdf.online/og/home.svg';
const appUrl = getAppUrl();
---

<MarketingLayout title={title} description={description} canonical={canonical} image={image}>
  <div class="page-shell">
    <section class="section intro">
      <span class="eyebrow">About</span>
      <h1>LocalPDF is built for focused PDF work in one place</h1>
      <p class="section-intro">
        LocalPDF exists for practical PDF work that stays closer to the user and the file.
        The product direction is simple: make core workflows easy to start, keep trust clear, and
        give users one place to finish common PDF jobs.
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">What LocalPDF is optimizing for</h2>
      <div class="card-grid">
        <div class="card">
          <h3>Practical PDF jobs</h3>
          <p>Edit, merge, OCR, compress, split, sign, and convert workflows are easy to find and easy to start.</p>
        </div>
        <div class="card">
          <h3>Local-first handling</h3>
          <p>The product gives users a workflow that begins on their device when the document is sensitive or operationally important.</p>
        </div>
        <div class="card">
          <h3>Clear product structure</h3>
          <p>Core workflows are easier to understand and compare when the product stays focused on the jobs users actually need to finish.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Core principles</h2>
      <div class="principles">
        <article class="principle">
          <strong>Trust sounds factual</strong>
          <p>Privacy and security claims stay inside what the product can explain clearly.</p>
        </article>
        <article class="principle">
          <strong>The app is the center</strong>
          <p>Marketing pages explain the workflows and remove hesitation before the click. The product does the real work.</p>
        </article>
        <article class="principle">
          <strong>Compact beats sprawling</strong>
          <p>A focused product is easier to trust and easier to use than a sprawling catalog of overlapping tools.</p>
        </article>
      </div>
    </section>

    <section class="section final-band">
      <div>
        <span class="eyebrow">Next step</span>
        <h2 class="section-title">Use the trust pages to judge the product honestly</h2>
        <p class="section-intro">
          The homepage explains the product. Feature pages explain the jobs. FAQ and Security answer the trust questions before you open the app.
        </p>
      </div>
      <div class="cta-row">
        <a class="btn-primary" href={appUrl}>Open LocalPDF</a>
        <a class="btn-secondary" href="/security">Read Security</a>
      </div>
    </section>
  </div>
</MarketingLayout>

<style>
  .intro h1 {
    font-size: clamp(3rem, 5vw, 5rem);
    margin-top: 18px;
    margin-bottom: 18px;
    max-width: 11ch;
  }

  .principles {
    display: grid;
    gap: 14px;
  }

  .principle {
    padding: 20px 22px;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .principle strong {
    display: block;
    margin-bottom: 8px;
    font-size: 1.05rem;
  }

  .final-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
</style>
