---
import MarketingLayout from '../layouts/MarketingLayout.astro';
import { featurePages } from '../data/featurePages';
import { getAppUrl } from '../utils/app-url';

const title = 'Private PDF workflows that stay on your device | LocalPDF';
const description = 'LocalPDF helps you edit, merge, OCR, compress, split, sign, and convert PDFs in one local-first workflow without an upload-first handoff.';
const canonical = 'https://localpdf.online/';
const image = 'https://localpdf.online/screenshots/v6-workspace-1.png';
const imageAlt = 'LocalPDF workspace showing local PDF editing and document workflow tools';
const appUrl = getAppUrl();

const websiteSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'LocalPDF',
    url: canonical,
    description,
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://localpdf.online/features/{feature}',
      'query-input': 'required name=feature',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'LocalPDF',
    url: canonical,
    logo: 'https://localpdf.online/logos/localpdf-header-96x96.png',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'LocalPDF',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Web',
    url: canonical,
    description,
    featureList: [
      'Edit PDF locally',
      'Merge PDF locally',
      'Run OCR on scanned PDFs',
      'Compress PDF files',
      'Split PDF pages',
      'Sign PDF documents',
      'Convert PDF and document formats',
    ],
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'USD',
    },
    screenshot: [
      'https://localpdf.online/screenshots/v6-workspace-1.png',
      'https://localpdf.online/screenshots/v6-workspace-2.png',
    ],
  },
];

const primaryFeatures = featurePages.filter((page) => [
  'edit-pdf',
  'merge-pdf',
  'ocr-pdf',
  'compress-pdf',
  'split-pdf',
  'convert-pdf',
].includes(page.slug));

const popularGuides = [
  {
    href: '/blog/how-to-merge-pdf-files',
    title: 'How to Merge PDF Files',
    description: 'A practical guide to combining PDFs, keeping order under control, and exporting one clean file.',
  },
  {
    href: '/blog/edit-text-in-pdf-guide',
    title: 'How to Edit Text in PDF Files',
    description: 'Learn when to replace text, cover sensitive sections, and handle direct PDF edits with more control.',
  },
  {
    href: '/blog/ocr-pdf-extract-text',
    title: 'OCR PDF: Extract Text from Scanned Documents',
    description: 'Turn scanned PDFs into searchable files and understand when OCR should be the next step in the workflow.',
  },
];
---

<MarketingLayout
  title={title}
  description={description}
  canonical={canonical}
  image={image}
  imageAlt={imageAlt}
  schema={websiteSchema}
>
  <div class="page-shell">
    <section class="hero section">
      <div class="hero-copy">
        <span class="eyebrow">Privacy-first PDF app</span>
        <h1>Private PDF workflows that stay on your device</h1>
        <p class="hero-text">
          Edit, merge, OCR, compress, split, sign, and convert PDFs in one place without
          turning every document into an upload-first workflow.
        </p>
        <div class="cta-row">
          <a class="btn-primary" href={appUrl}>Open LocalPDF</a>
          <a class="btn-secondary" href="/security">See How Local Processing Works</a>
        </div>
        <div class="hero-notes">
          <span>Local-first handling for sensitive files</span>
          <span>One workspace for real PDF jobs</span>
          <span>Clear path from file to finished result</span>
        </div>
      </div>

      <div class="hero-panel">
        <div class="panel-top">
          <span>Workspace</span>
          <strong>LocalPDF</strong>
        </div>
        <div class="panel-body">
          <div class="metric-row">
            <div>
              <small>Primary jobs</small>
              <strong>Edit, Merge, OCR, Convert</strong>
            </div>
            <div>
              <small>Why it exists</small>
              <strong>Keep PDF work close to the file</strong>
            </div>
          </div>
          <div class="app-screenshot-wrapper">
            <img 
              src="/screenshots/v6-workspace-1.png" 
              alt="LocalPDF Studio Workspace V6" 
              class="app-screenshot"
              loading="eager"
              decoding="async"
              width="1800"
              height="1125"
            />
          </div>
          <p class="panel-caption">Studio keeps document work in one local-first workspace instead of splitting it across utility pages.</p>
        </div>
      </div>
    </section>

    <section class="section trust-strip">
      <div class="trust-item">
        <strong>No upload workflow</strong>
        <p>Built for jobs where documents need to stay close to the user.</p>
      </div>
      <div class="trust-item">
        <strong>One workspace</strong>
        <p>Open the app and continue the job instead of bouncing across utility pages.</p>
      </div>
      <div class="trust-item">
        <strong>Trust up front</strong>
        <p>Security and FAQ are easy to find because trust matters before the first click.</p>
      </div>
    </section>

    <section class="section decision-strip">
      <div class="decision-copy">
        <h2 class="section-title">When LocalPDF is the better fit</h2>
        <p class="section-intro">
          LocalPDF is a better fit when the document matters, the task is clear, and you want to
          start working on the file immediately instead of sending it into an upload queue.
        </p>
      </div>
      <div class="decision-box">
        <strong>Use LocalPDF when</strong>
        <ul class="bullet-list">
          <li>You want one workspace instead of many disconnected utility pages</li>
          <li>The document is internal, sensitive, or operationally important</li>
          <li>The task is editing, merging, OCR, splitting, signing, compression, or conversion</li>
        </ul>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Core workflows inside the app</h2>
      <p class="section-intro">
        These are the main PDF jobs people come to LocalPDF to finish.
      </p>
      <div class="card-grid feature-grid">
        {primaryFeatures.map((feature) => (
          <a class="feature-card" href={`/features/${feature.slug}`}>
            <span class="feature-label">{feature.eyebrow}</span>
            <h3>{feature.title}</h3>
            <p>{feature.metaDescription}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section split-layout">
      <div>
        <h2 class="section-title">Why local processing changes the decision</h2>
        <p class="section-intro">
          Local processing matters most when the document is sensitive, operational, or simply too
          important for an upload-first flow. The value is practical: less exposure, less waiting,
          and a faster path to the result.
        </p>
      </div>
      <div class="callout-list">
        <div class="callout">
          <strong>Less exposure by default</strong>
          <p>Keeping the first step local is easier to justify for contracts, scans, invoices, and internal files.</p>
        </div>
        <div class="callout">
          <strong>Less friction before action</strong>
          <p>Open the app, load the document, finish the job, and export the result without extra waiting loops.</p>
        </div>
        <div class="callout">
          <strong>Less route sprawl</strong>
          <p>Core workflows are easy to understand, compare, and open without digging through dozens of lookalike tool pages.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">What LocalPDF is built for</h2>
      <div class="card-grid">
        <div class="card">
          <h3>Sensitive internal documents</h3>
          <p>Contracts, invoices, records, and drafts that users do not want to treat as disposable uploads.</p>
        </div>
        <div class="card">
          <h3>Fast operational PDF work</h3>
          <p>Merging, splitting, compressing, and preparing files without waiting for remote processing loops.</p>
        </div>
        <div class="card">
          <h3>One product surface</h3>
          <p>A PDF app that feels like a workspace, not a list of unrelated online tools.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">A better fit for sensitive and practical PDF work</h2>
      <div class="card-grid comparison-grid">
        <div class="card">
          <h3>What you get</h3>
          <ul class="bullet-list">
            <li>A PDF app built around core document workflows</li>
            <li>A privacy-first product for users who want processing closer to the file</li>
            <li>Clear routes into editing, merging, OCR, compression, signing, splitting, and conversion</li>
          </ul>
        </div>
        <div class="card">
          <h3>What you avoid</h3>
          <ul class="bullet-list">
            <li>No maze of disconnected one-purpose tool pages</li>
            <li>No privacy messaging without a usable product behind it</li>
            <li>No assumption that every file should be uploaded first</li>
          </ul>
        </div>
        <div class="card">
          <h3>Why people choose it</h3>
          <ul class="bullet-list">
            <li>The app is central to the experience</li>
            <li>The trust story is concrete and easy to verify</li>
            <li>The next step is clear before you have to commit</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Popular guides before you open the app</h2>
      <p class="section-intro">
        Start with a guide if you want to compare approaches first, then move into LocalPDF when the workflow is clear.
      </p>
      <div class="card-grid feature-grid">
        {popularGuides.map((guide) => (
          <a class="feature-card" href={guide.href}>
            <span class="feature-label">Guide</span>
            <h3>{guide.title}</h3>
            <p>{guide.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="section faq-preview">
      <div>
        <span class="eyebrow">Trust and clarity</span>
        <h2 class="section-title">Questions users ask before opening the app</h2>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <strong>Do I have to upload my PDF first?</strong>
          <p>No. LocalPDF is built around local-first handling for practical PDF work.</p>
        </div>
        <div class="faq-item">
          <strong>What jobs does LocalPDF actually cover?</strong>
          <p>Edit, merge, OCR, compress, split, sign, and conversion workflows are the current core jobs.</p>
        </div>
        <div class="faq-item">
          <strong>Where should I verify the trust model?</strong>
          <p>Start with Security and FAQ. They explain how LocalPDF handles local processing and privacy in practical terms.</p>
        </div>
      </div>
    </section>

    <section class="section final-band">
      <div>
        <span class="eyebrow">Next step</span>
        <h2 class="section-title">Open the app, then judge the workflow directly</h2>
        <p class="section-intro">
          If LocalPDF is the right fit, the value is already clear: practical PDF work, a faster path
          to the result, and local-first handling for important documents.
        </p>
      </div>
      <div class="cta-row">
        <a class="btn-primary" href={appUrl}>Open LocalPDF</a>
        <a class="btn-secondary" href="/faq">Read FAQ</a>
      </div>
    </section>
  </div>

</MarketingLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 24px;
    align-items: stretch;
    margin-top: 12px;
  }

  .hero-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 18px;
  }

  .hero h1 {
    font-size: clamp(2.8rem, 5.8vw, 5rem);
    max-width: 9ch;
    line-height: 0.92;
  }

  .hero-text {
    max-width: 700px;
    font-size: 1.08rem;
  }

  .hero-notes {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 4px;
  }

  .hero-notes span {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 0 14px;
    border-radius: 999px;
    background: rgba(217, 235, 225, 0.85);
    color: #24353f;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .hero-panel {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--line);
    border-radius: 30px;
    background: linear-gradient(180deg, rgba(255, 253, 249, 0.96), rgba(247, 244, 239, 0.8));
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .panel-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid var(--line);
    font-size: 0.92rem;
    color: #536674;
  }

  .panel-body {
    padding: 20px;
    display: grid;
    gap: 18px;
  }

  .panel-caption {
    font-size: 0.96rem;
    color: #536674;
  }

  .metric-row {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 12px;
  }

  .metric-row div {
    padding: 14px;
    border-radius: 18px;
    background: rgba(217, 235, 225, 0.5);
  }

  .metric-row small {
    display: block;
    margin-bottom: 8px;
    color: #536674;
  }

  .metric-row strong {
    color: var(--text);
  }


  .app-screenshot-wrapper {
    margin-top: 4px;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid rgba(24, 32, 40, 0.08);
    box-shadow: 0 12px 32px rgba(26, 34, 39, 0.08);
    background: #fff;
    display: flex;
    justify-content: center;
    align-items: flex-start;
  }

  .app-screenshot {
    width: 100%;
    height: auto;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  .trust-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 16px;
  }

  .trust-item {
    padding: 10px 8px;
  }

  .trust-item strong {
    display: block;
    margin-bottom: 8px;
    font-size: 1rem;
  }

  .feature-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .decision-strip {
    display: grid;
    grid-template-columns: 1fr 0.9fr;
    gap: 20px;
    align-items: start;
  }

  .decision-box {
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(243, 201, 146, 0.24), rgba(255, 253, 249, 0.95));
  }

  .decision-box strong {
    display: block;
    margin-bottom: 12px;
    font-size: 1.05rem;
  }

  .feature-card {
    display: block;
    padding: 22px;
    border: 1px solid var(--line);
    border-radius: 24px;
    background: var(--surface);
    text-decoration: none;
    box-shadow: 0 10px 24px rgba(26, 34, 39, 0.04);
  }

  .feature-card:hover,
  .feature-card:focus-visible {
    border-color: rgba(20, 32, 40, 0.18);
    transform: translateY(-2px);
  }

  .feature-label {
    display: inline-block;
    margin-bottom: 12px;
    color: #8a572d;
    font-weight: 800;
    font-size: 0.84rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .feature-card h3 {
    font-size: 1.5rem;
    margin-bottom: 12px;
  }

  .comparison-grid .card {
    min-height: 100%;
  }

  .split-layout {
    display: grid;
    grid-template-columns: 1fr 0.95fr;
    gap: 20px;
    align-items: start;
  }

  .callout-list {
    display: grid;
    gap: 14px;
  }

  .callout {
    padding: 18px 20px;
    border-radius: 20px;
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .callout strong {
    display: block;
    margin-bottom: 8px;
    font-size: 1.05rem;
  }

  .final-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }

  .faq-preview {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 20px;
    align-items: start;
  }

  .faq-list {
    display: grid;
    gap: 14px;
  }

  .faq-item {
    padding: 18px 20px;
    border: 1px solid var(--line);
    border-radius: 22px;
    background: var(--surface);
  }

  .faq-item strong {
    display: block;
    margin-bottom: 10px;
    font-size: 1.05rem;
    color: var(--text);
  }

  @media (max-width: 960px) {
    .hero,
    .split-layout,
    .trust-strip,
    .decision-strip,
    .feature-grid,
    .faq-preview {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .hero {
      margin-top: 16px;
    }

    .hero h1 {
      font-size: clamp(2.4rem, 11vw, 3.6rem);
    }

    .metric-row {
      grid-template-columns: 1fr;
    }
  }
</style>
