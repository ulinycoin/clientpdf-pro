---
import MarketingLayout from '../layouts/MarketingLayout.astro';

const title = 'Terms | LocalPDF';
const description = 'Basic service terms and usage boundaries for the LocalPDF website and app.';
const canonical = 'https://localpdf.online/terms';
const image = 'https://localpdf.online/og/home.svg';
---

<MarketingLayout title={title} description={description} canonical={canonical} image={image}>
  <div class="page-shell">
    <section class="section intro">
      <span class="eyebrow">Terms</span>
      <h1>Simple terms for using LocalPDF responsibly</h1>
      <p class="section-intro">
        These terms define the current service boundaries for LocalPDF in plain language and stay aligned with the actual product experience.
      </p>
    </section>

    <section class="section">
      <h2 class="section-title">Current service framing</h2>
      <div class="card-grid">
        <div class="card">
          <h3>Product status</h3>
          <p>LocalPDF is an actively evolving PDF product. Features, packaging, and routing may change as the product matures.</p>
        </div>
        <div class="card">
          <h3>User responsibility</h3>
          <p>Users are responsible for the documents they process and are expected to keep backups of important files before relying on any single export result.</p>
        </div>
        <div class="card">
          <h3>Service scope</h3>
          <p>LocalPDF is provided as a practical PDF tool, and features, workflows, or availability may change over time.</p>
        </div>
      </div>
    </section>

    <section class="section">
      <h2 class="section-title">Working rules</h2>
      <div class="rules">
        <article class="rule">
          <strong>Use LocalPDF responsibly</strong>
          <p>Do not process documents you have no right to handle.</p>
        </article>
        <article class="rule">
          <strong>Keep backups of important files</strong>
          <p>Important documents should not depend on one browser session or one export attempt.</p>
        </article>
        <article class="rule">
          <strong>Expect iteration</strong>
          <p>The product, pricing, and packaging may evolve over time as the app develops.</p>
        </article>
      </div>
    </section>

    <section class="section final-band">
      <div>
        <span class="eyebrow">Related pages</span>
        <h2 class="section-title">Terms work better when they stay connected to Privacy and Security</h2>
        <p class="section-intro">
          Use Terms for service boundaries, Privacy for data-handling language, and Security for the trust model that sits behind the workflow.
        </p>
      </div>
      <div class="cta-row">
        <a class="btn-primary" href="/privacy">Read Privacy</a>
        <a class="btn-secondary" href="/security">Read Security</a>
      </div>
    </section>
  </div>
</MarketingLayout>

<style>
  .intro h1 {
    font-size: clamp(3rem, 5vw, 5rem);
    margin-top: 18px;
    margin-bottom: 18px;
    max-width: 12ch;
  }

  .rules {
    display: grid;
    gap: 14px;
  }

  .rule {
    padding: 20px 22px;
    border-radius: 22px;
    border: 1px solid var(--line);
    background: var(--surface);
  }

  .rule strong {
    display: block;
    margin-bottom: 8px;
    font-size: 1rem;
  }

  .final-band {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }
</style>
