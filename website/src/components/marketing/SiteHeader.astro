---
import { getAppUrl } from '../../utils/app-url';

const appUrl = getAppUrl();
---

<header class="site-header">
  <div class="header-shell">
    <a href="/" class="brand">
      <img src="/logos/localpdf-header-64x64.png" alt="LocalPDF" width="36" height="36" />
      <span>LocalPDF</span>
    </a>

    <nav class="nav">
      <div class="dropdown" tabindex="0">
        <span class="nav-link dropdown-toggle">
          Edit <span class="caret">▾</span>
        </span>
        <div class="dropdown-menu">
          <a href="/features/edit-pdf" class="dropdown-item">Edit PDF</a>
          <a href="/features/merge-pdf" class="dropdown-item">Merge PDF</a>
          <a href="/features/split-pdf" class="dropdown-item">Split PDF</a>
          <a href="/features/sign-pdf" class="dropdown-item">Sign PDF</a>
        </div>
      </div>

      <div class="dropdown" tabindex="0">
        <span class="nav-link dropdown-toggle">
          Convert <span class="caret">▾</span>
        </span>
        <div class="dropdown-menu">
          <a href="/features/ocr-pdf" class="dropdown-item">OCR PDF</a>
          <a href="/features/compress-pdf" class="dropdown-item">Compress PDF</a>
          <a href="/features/convert-pdf" class="dropdown-item">Convert to PDF</a>
        </div>
      </div>

      <div class="dropdown" tabindex="0">
        <span class="nav-link dropdown-toggle">
          Resources <span class="caret">▾</span>
        </span>
        <div class="dropdown-menu">
          <a href="/blog" class="dropdown-item">Blog</a>
          <a href="/security" class="dropdown-item">Security</a>
          <a href="/faq" class="dropdown-item">FAQ</a>
        </div>
      </div>
    </nav>

    <a href={appUrl} class="header-cta">Open LocalPDF</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 1000;
    padding: 16px 20px 0;
  }

  .header-shell {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding: 14px 18px;
    border: 1px solid rgba(24, 28, 32, 0.08);
    border-radius: 20px;
    background: rgba(250, 247, 242, 0.84);
    box-shadow: 0 8px 30px rgba(26, 34, 39, 0.06);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: #142028;
    text-decoration: none;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .brand span {
    font-size: 1.1rem;
  }

  .nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 18px;
    align-items: center;
  }

  .nav-link {
    color: #425361 !important;
    text-decoration: none !important;
    font-size: 0.95rem;
    font-weight: 600;
    background: transparent !important;
    border: none !important;
    outline: none !important;
    padding: 8px 12px;
    margin: 0;
    cursor: pointer;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease, background-color 0.2s;
    border-radius: 8px;
  }

  .nav-link:hover,
  .nav-link:focus-within,
  .dropdown:hover .dropdown-toggle,
  .dropdown:focus-within .dropdown-toggle {
    color: #142028 !important;
    background: rgba(24, 32, 40, 0.05) !important;
  }

  .dropdown {
    position: relative;
    outline: none;
  }

  .caret {
    font-size: 0.75rem;
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .dropdown:hover .caret,
  .dropdown:focus-within .caret {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: #ffffff !important;
    border: 1px solid rgba(24, 28, 32, 0.12) !important;
    border-radius: 12px;
    padding: 8px;
    min-width: 180px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 40px rgba(26, 34, 39, 0.08) !important;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 2000;
  }

  .dropdown:hover .dropdown-menu,
  .dropdown:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .dropdown-item {
    display: block !important;
    padding: 10px 16px !important;
    color: #425361 !important;
    text-decoration: none !important;
    font-size: 0.9rem !important;
    font-weight: 600 !important;
    border-radius: 8px;
    transition: all 0.2s ease !important;
    white-space: nowrap;
    width: 100%;
    box-sizing: border-box;
    text-align: left;
  }

  .dropdown-item:hover,
  .dropdown-item:focus-visible {
    background: #f6f3ee !important;
    color: #142028 !important;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 44px;
    padding: 0 18px;
    border-radius: 999px;
    background: #142028;
    color: #f8f5ef;
    text-decoration: none;
    font-weight: 700;
  }

  @media (max-width: 960px) {
    .header-shell {
      flex-wrap: wrap;
      justify-content: center;
    }
  }

  @media (max-width: 720px) {
    .site-header {
      padding: 12px 12px 0;
    }

    .header-shell {
      border-radius: 16px;
      justify-content: center;
    }

    .nav {
      width: 100%;
      flex-wrap: nowrap;
      justify-content: flex-start;
      overflow-x: auto;
      padding-bottom: 2px;
      scrollbar-width: none;
    }

    .nav::-webkit-scrollbar {
      display: none;
    }
  }
</style>
