---
import LanguagePicker from './LanguagePicker.astro';
import { getAppUrl } from '../utils/app-url';

const { lang = 'en' } = Astro.props;
const langPrefix = lang === 'en' ? '' : `/${lang}`;

const navLabels = {
  en: { 
    edit: 'Edit PDF', merge: 'Merge PDF', split: 'Split PDF', sign: 'Sign PDF',
    convert: 'Convert', ocr: 'OCR PDF', compress: 'Compress PDF', toPdf: 'Convert to PDF',
    resources: 'Resources', security: 'Security', faq: 'FAQ', about: 'About', blog: 'Blog',
    open: 'Open LocalPDF' 
  },
  de: { 
    edit: 'Edit PDF', merge: 'Merge PDF', split: 'Split PDF', sign: 'Sign PDF',
    convert: 'Convert', ocr: 'OCR PDF', compress: 'Compress PDF', toPdf: 'Convert to PDF',
    resources: 'Resources', security: 'Security', faq: 'FAQ', about: 'About', blog: 'Blog',
    open: 'Open LocalPDF' 
  },
  ja: { 
    edit: 'Edit PDF', merge: 'Merge PDF', split: 'Split PDF', sign: 'Sign PDF',
    convert: 'Convert', ocr: 'OCR PDF', compress: 'Compress PDF', toPdf: 'Convert to PDF',
    resources: 'Resources', security: 'Security', faq: 'FAQ', about: 'About', blog: 'Blog',
    open: 'Open LocalPDF' 
  }
}[lang] || { 
  edit: 'Edit PDF', merge: 'Merge PDF', split: 'Split PDF', sign: 'Sign PDF',
  convert: 'Convert', ocr: 'OCR PDF', compress: 'Compress PDF', toPdf: 'Convert to PDF',
  resources: 'Resources', security: 'Security', faq: 'FAQ', about: 'About', blog: 'Blog',
  open: 'Open LocalPDF' 
};
const appUrl = getAppUrl();
---
<header>
  <a href={langPrefix || "/"} class="logo">
    <img src="/logos/localpdf-header-64x64.png" alt="LocalPDF" class="logo-image" width="40" height="40" />
    <div class="logo-text">
      <div class="logo-title">LocalPDF</div>
      <div class="logo-subtitle">Local</div>
    </div>
  </a>
  <nav>
    <div class="dropdown" tabindex="0">
      <span class="nav-link dropdown-toggle">
        {navLabels.edit} <span class="caret">▾</span>
      </span>
      <div class="dropdown-menu">
        <a href="/features/edit-pdf" class="dropdown-item">{navLabels.edit}</a>
        <a href="/features/merge-pdf" class="dropdown-item">{navLabels.merge}</a>
        <a href="/features/split-pdf" class="dropdown-item">{navLabels.split}</a>
        <a href="/features/sign-pdf" class="dropdown-item">{navLabels.sign}</a>
      </div>
    </div>

    <div class="dropdown" tabindex="0">
      <span class="nav-link dropdown-toggle">
        {navLabels.convert} <span class="caret">▾</span>
      </span>
      <div class="dropdown-menu">
        <a href="/features/ocr-pdf" class="dropdown-item">{navLabels.ocr}</a>
        <a href="/features/compress-pdf" class="dropdown-item">{navLabels.compress}</a>
        <a href="/features/convert-pdf" class="dropdown-item">{navLabels.toPdf}</a>
      </div>
    </div>

    <div class="dropdown" tabindex="0">
      <span class="nav-link dropdown-toggle">
        {navLabels.resources} <span class="caret">▾</span>
      </span>
      <div class="dropdown-menu">
        <a href="/blog" class="dropdown-item">{navLabels.blog}</a>
        <a href="/security" class="dropdown-item">{navLabels.security}</a>
        <a href="/faq" class="dropdown-item">{navLabels.faq}</a>
        <a href="/about" class="dropdown-item">{navLabels.about}</a>
      </div>
    </div>

    <LanguagePicker lang={lang} />
  </nav>
  
  <div class="mobile-actions">
    <a href={appUrl} class="mobile-extension-cta">
      {navLabels.open}
    </a>
    <div class="mobile-lang-picker">
       <LanguagePicker lang={lang} />
    </div>
  </div>
</header>

<style>
  header {
    position: fixed;
    top: 0;
    width: 100%;
    padding: 20px 7vw;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(3, 7, 18, 0.75);
    backdrop-filter: blur(16px);
    z-index: 1000;
    border-bottom: 1px solid var(--glass-border);
    gap: 20px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Outfit', sans-serif;
    font-weight: 800;
    font-size: 1.5rem;
    color: #fff;
    text-decoration: none;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    flex-shrink: 0;
  }

  .logo:hover { transform: scale(1.02); }

  .logo-image {
    width: 40px;
    height: 40px;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .logo:hover .logo-image { transform: scale(1.05) rotate(3deg); }

  .logo-text { display: flex; flex-direction: column; gap: 0; }
  .logo-title {
    font-size: 1.4rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #fff;
    line-height: 1.2;
  }
  .logo-subtitle {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--accent-light);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1;
  }

  nav { display: flex; gap: 24px; align-items: center; }
  
  .mobile-actions { display: none; align-items: center; gap: 12px; }
  .mobile-lang-picker { display: none; }
  .mobile-extension-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 6px 12px;
    border-radius: 999px;
    background: linear-gradient(135deg, #3b82f6, #60a5fa);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid rgba(255, 255, 255, 0.2);
    white-space: nowrap;
  }

  .nav-link {
    color: var(--text-muted) !important;
    text-decoration: none !important;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    padding: 6px 8px;
    position: relative;
    background: transparent !important;
    border: none !important;
    outline: none !important;
    cursor: pointer;
    font-family: inherit;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    border-radius: 8px;
  }

  .nav-link:hover, 
  .nav-link:focus-within,
  .dropdown:hover .dropdown-toggle,
  .dropdown:focus-within .dropdown-toggle { 
    color: #fff !important; 
    background: rgba(255, 255, 255, 0.05) !important;
  }

  .dropdown {
    position: relative;
    outline: none;
  }

  .caret {
    font-size: 0.75rem;
    transition: transform 0.2s ease;
    display: inline-block;
  }

  .dropdown:hover .caret,
  .dropdown:focus-within .caret {
    transform: rotate(180deg);
  }

  .dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    background: rgba(24, 24, 27, 0.95) !important;
    backdrop-filter: blur(12px);
    border: 1px solid var(--glass-border) !important;
    border-radius: 12px;
    padding: 8px;
    min-width: 180px;
    opacity: 0;
    visibility: hidden;
    transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.4) !important;
    pointer-events: none;
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 2000;
  }

  .dropdown:hover .dropdown-menu,
  .dropdown:focus-within .dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .dropdown-item {
    display: block !important;
    padding: 8px 16px !important;
    color: var(--text-muted) !important;
    text-decoration: none !important;
    font-size: 0.85rem !important;
    font-weight: 500 !important;
    border-radius: 8px;
    transition: all 0.2s ease !important;
    white-space: nowrap;
    width: 100%;
    box-sizing: border-box;
    text-align: left;
  }

  .dropdown-item:hover,
  .dropdown-item:focus-visible {
    background: rgba(255, 255, 255, 0.08) !important;
    color: #fff !important;
    transform: translateX(4px);
  }

  @media (max-width: 768px) {
    header { padding: 16px 5vw; }
    nav { display: none; }
    .logo-subtitle { display: none; }
    .mobile-actions { display: flex; }
    .mobile-lang-picker { display: block; }
  }
</style>
