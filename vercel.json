{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build:all",
  "outputDirectory": "dist",
  "framework": null,
  "installCommand": "npm install",
  "devCommand": "npm run dev:all",
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.localpdf.online"
        }
      ],
      "destination": "https://localpdf.online/:path*",
      "statusCode": 301
    },
    {
      "source": "/edit-text-pdf",
      "destination": "/features/edit-pdf",
      "statusCode": 308
    },
    {
      "source": "/add-text-pdf",
      "destination": "/features/edit-pdf",
      "statusCode": 308
    },
    {
      "source": "/merge-pdf",
      "destination": "/features/merge-pdf",
      "statusCode": 308
    },
    {
      "source": "/ocr-pdf",
      "destination": "/features/ocr-pdf",
      "statusCode": 308
    },
    {
      "source": "/compress-pdf",
      "destination": "/features/compress-pdf",
      "statusCode": 308
    },
    {
      "source": "/split-pdf",
      "destination": "/features/split-pdf",
      "statusCode": 308
    },
    {
      "source": "/sign-pdf",
      "destination": "/features/sign-pdf",
      "statusCode": 308
    },
    {
      "source": "/pdf-to-word",
      "destination": "/features/convert-pdf",
      "statusCode": 308
    },
    {
      "source": "/word-to-pdf",
      "destination": "/features/convert-pdf",
      "statusCode": 308
    },
    {
      "source": "/images-to-pdf",
      "destination": "/features/convert-pdf",
      "statusCode": 308
    },
    {
      "source": "/pdf-to-images",
      "destination": "/features/convert-pdf",
      "statusCode": 308
    },
    {
      "source": "/add-form-fields-pdf",
      "destination": "/features/edit-pdf",
      "statusCode": 308
    },
    {
      "source": "/delete-pages-pdf",
      "destination": "/features/split-pdf",
      "statusCode": 308
    },
    {
      "source": "/extract-pages-pdf",
      "destination": "/features/split-pdf",
      "statusCode": 308
    },
    {
      "source": "/extract-images-pdf",
      "destination": "/features/convert-pdf",
      "statusCode": 308
    },
    {
      "source": "/organize-pdf",
      "destination": "/features/edit-pdf",
      "statusCode": 308
    },
    {
      "source": "/rotate-pdf",
      "destination": "/features/edit-pdf",
      "statusCode": 308
    },
    {
      "source": "/watermark-pdf",
      "destination": "/features/edit-pdf",
      "statusCode": 308
    },
    {
      "source": "/protect-pdf",
      "destination": "/security",
      "statusCode": 308
    },
    {
      "source": "/flatten-pdf",
      "destination": "/features/edit-pdf",
      "statusCode": 308
    },
    {
      "source": "/tables-pdf",
      "destination": "/features/convert-pdf",
      "statusCode": 308
    },
    {
      "source": "/comparison",
      "destination": "/faq",
      "statusCode": 308
    },
    {
      "source": "/learn",
      "destination": "/faq",
      "statusCode": 308
    },
    {
      "source": "/learn/:slug",
      "destination": "/faq",
      "statusCode": 308
    },
    {
      "source": "/extension",
      "destination": "/",
      "statusCode": 308
    },
    {
      "source": "/(legal-privacy-pdf|finance-privacy-pdf|medical-privacy-pdf)",
      "destination": "/security",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)",
      "destination": "/",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)/(edit-text-pdf|add-text-pdf)",
      "destination": "/features/edit-pdf",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)/merge-pdf",
      "destination": "/features/merge-pdf",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)/ocr-pdf",
      "destination": "/features/ocr-pdf",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)/compress-pdf",
      "destination": "/features/compress-pdf",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)/split-pdf",
      "destination": "/features/split-pdf",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)/sign-pdf",
      "destination": "/features/sign-pdf",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)/(pdf-to-word|word-to-pdf|images-to-pdf|pdf-to-images)",
      "destination": "/features/convert-pdf",
      "statusCode": 308
    },
    {
      "source": "/(de|ja)/:path*",
      "destination": "/",
      "statusCode": 308
    }
  ],
  "rewrites": [
    {
      "source": "/ingest/static/:path*",
      "destination": "https://eu-assets.i.posthog.com/static/:path*"
    },
    {
      "source": "/ingest/:path*",
      "destination": "https://eu.i.posthog.com/:path*"
    },
    {
      "source": "/app",
      "destination": "/app/index.html"
    },
    {
      "source": "/app/:path*",
      "destination": "/app/index.html"
    },
    {
      "source": "/(about|privacy|terms|faq|security)",
      "destination": "/$1.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/logos/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/fonts/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/blog-images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "trailingSlash": false,
  "cleanUrls": true
}
